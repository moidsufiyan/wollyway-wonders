# WollyWay Backend Environment Variables Template
# Copy this file to .env and populate with your credentials. Do NOT commit the .env file.

# Application Configuration
NODE_ENV=development
PORT=5000
CORS_ORIGIN=http://localhost:3000

# Database Configuration
MONGO_URI=mongodb://localhost:27017/wollyway

# Redis Configuration
REDIS_URI=redis://localhost:6379

# JWT Secrets (Minimum 32 characters)
JWT_ACCESS_SECRET=your_super_secret_jwt_access_token_signing_key_here
JWT_REFRESH_SECRET=your_super_secret_jwt_refresh_token_signing_key_here

# Cloudinary Credentials (For image transformations and management)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Razorpay Credentials (For payment gateway integrations)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
